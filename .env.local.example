# Local development only. Copy this file to `.env.local` and fill in the values you actually need.
# Do not commit your real `.env.local`.

# Optional: enables the AI summary button locally and on your own server
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Optional: only needed if you want to test /api/redeploy locally
CRON_SECRET=
VERCEL_DEPLOY_HOOK_URL=
